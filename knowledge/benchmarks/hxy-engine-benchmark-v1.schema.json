{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hxyos.local/schemas/hxy-engine-benchmark-v1.schema.json",
  "title": "HXYOS Engine Benchmark V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "benchmark_id",
    "candidate_engine",
    "hard_gates",
    "cases"
  ],
  "properties": {
    "version": { "const": "hxy-engine-benchmark.v1" },
    "benchmark_id": { "type": "string", "minLength": 3, "maxLength": 120 },
    "candidate_engine": { "$ref": "#/$defs/engineDescriptor" },
    "hard_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_unauthorized_evidence_exposure",
        "max_authority_state_violations",
        "max_prohibited_expression_misses",
        "max_unapproved_writes"
      ],
      "properties": {
        "max_unauthorized_evidence_exposure": { "const": 0 },
        "max_authority_state_violations": { "const": 0 },
        "max_prohibited_expression_misses": { "const": 0 },
        "max_unapproved_writes": { "const": 0 }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "engineDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "capabilities",
        "license_id",
        "deployment",
        "data_export",
        "healthcheck",
        "rollback"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "version": { "type": "string", "minLength": 1, "maxLength": 120 },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 160 }
        },
        "license_id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "deployment": { "type": "string", "minLength": 1, "maxLength": 160 },
        "data_export": { "type": "string", "minLength": 1, "maxLength": 240 },
        "healthcheck": { "type": "string", "minLength": 1, "maxLength": 240 },
        "rollback": { "type": "string", "minLength": 1, "maxLength": 240 }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "role",
        "assignment_scope",
        "task",
        "allowed_evidence_ids",
        "forbidden_evidence_ids",
        "expected_authority",
        "risk_expectations",
        "minimum_useful_outcome",
        "budget"
      ],
      "properties": {
        "case_id": { "type": "string", "minLength": 3, "maxLength": 120 },
        "role": {
          "enum": [
            "founder",
            "brand_operations",
            "store_manager",
            "store_employee",
            "knowledge_data_admin"
          ]
        },
        "assignment_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["assignment_id", "organization_id", "store_id"],
          "properties": {
            "assignment_id": { "type": "string", "minLength": 1, "maxLength": 160 },
            "organization_id": { "type": "string", "minLength": 1, "maxLength": 160 },
            "store_id": {
              "oneOf": [
                { "type": "string", "minLength": 1, "maxLength": 160 },
                { "type": "null" }
              ]
            }
          }
        },
        "task": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "purpose", "input"],
          "properties": {
            "type": { "type": "string", "minLength": 1, "maxLength": 120 },
            "purpose": { "type": "string", "minLength": 1, "maxLength": 240 },
            "input": { "type": "string", "minLength": 1, "maxLength": 1000 }
          }
        },
        "allowed_evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 160 }
        },
        "forbidden_evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 160 }
        },
        "expected_authority": {
          "enum": ["approved", "candidate", "reference", "insufficient"]
        },
        "risk_expectations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 160 }
        },
        "minimum_useful_outcome": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_latency_ms", "max_tokens", "max_cost_microunits"],
          "properties": {
            "max_latency_ms": { "type": "integer", "minimum": 1, "maximum": 600000 },
            "max_tokens": { "type": "integer", "minimum": 0, "maximum": 2000000 },
            "max_cost_microunits": { "type": "integer", "minimum": 0, "maximum": 1000000000000 }
          }
        }
      }
    }
  }
}
