{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hxyos.local/schemas/hxy-semantic-answer-run-v1.schema.json",
  "title": "HXYOS Semantic Answer Run V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "answers"],
  "properties": {
    "version": { "const": "hxy-semantic-answer-run.v1" },
    "answers": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "provider_name",
          "provider_version",
          "answer",
          "answer_authority",
          "evidence_ids",
          "evidence_authorities",
          "citations",
          "declared_outcomes",
          "policy_action",
          "guardrail_action",
          "latency_ms",
          "input_tokens",
          "output_tokens",
          "cost_microunits",
          "safe_trace"
        ],
        "properties": {
          "case_id": { "type": "string", "minLength": 1, "maxLength": 160 },
          "provider_name": { "type": "string", "minLength": 1, "maxLength": 160 },
          "provider_version": { "type": "string", "minLength": 1, "maxLength": 160 },
          "answer": { "type": "string", "maxLength": 50000 },
          "answer_authority": { "enum": ["approved", "candidate", "reference", "insufficient"] },
          "evidence_ids": { "$ref": "#/$defs/stringArray" },
          "evidence_authorities": {
            "type": "array",
            "items": { "enum": ["approved", "action_asset", "candidate", "reference", "private_reference", "process"] }
          },
          "citations": { "$ref": "#/$defs/stringArray" },
          "declared_outcomes": { "$ref": "#/$defs/stringArray" },
          "policy_action": { "enum": ["answer", "needs_review", "deny"] },
          "guardrail_action": { "enum": ["send", "revise_or_review", "deny"] },
          "latency_ms": { "type": "integer", "minimum": 0 },
          "input_tokens": { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 0 },
          "cost_microunits": { "type": "integer", "minimum": 0 },
          "safe_trace": { "type": "object" }
        }
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 160 }
    }
  }
}
