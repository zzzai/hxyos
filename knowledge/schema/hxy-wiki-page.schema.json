{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HXY Wiki Page",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "domain",
    "status",
    "sources",
    "confidence",
    "owner",
    "last_confirmed",
    "used_by",
    "risk_level"
  ],
  "properties": {
    "id": {"type": "string"},
    "type": {"type": "string"},
    "title": {"type": "string"},
    "domain": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["reference", "ai_structured", "current_candidate", "needs_review", "approved", "action_asset", "disputed", "superseded", "archived"]
    },
    "sources": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "owner": {"type": "string"},
    "last_confirmed": {"type": "string"},
    "used_by": {"type": "array", "items": {"type": "string"}},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high"]}
  }
}
