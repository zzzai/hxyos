# Install the limit_req_zone directive once inside the public Nginx `http` block.
limit_req_zone $binary_remote_addr zone=hxy_invite_redeem_per_ip:10m rate=6r/m;

server {
    listen 80;
    server_name hxyos.hexiaoyue.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name hxyos.hexiaoyue.com;

    # Keep the certificate directives from the existing managed TLS vhost.

    location = /api/v1/onboarding/invites/redeem {
        limit_req zone=hxy_invite_redeem_per_ip burst=3 nodelay;
        limit_req_status 429;
        client_max_body_size 1k;
        proxy_pass http://127.0.0.1:18081;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        client_max_body_size 11m;
        proxy_pass http://127.0.0.1:18081;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:18084;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
