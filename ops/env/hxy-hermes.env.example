# HXY Hermes Agent local environment.
# Copy to ops/env/hxy-hermes.env and fill real values locally.
# Do not commit ops/env/hxy-hermes.env.

# Official Hermes Agent release tag used for the HXY Docker build.
HXY_HERMES_IMAGE_TAG=v2026.6.19
HXY_HERMES_PREBUILT_IMAGE=nousresearch/hermes-agent:latest
HXY_HERMES_REPO_URL=https://github.com/NousResearch/hermes-agent.git
HXY_HERMES_SOURCE_DIR=/root/hxy/.hermes-source/hermes-agent

# Runtime file ownership inside the container.
# For root-owned server deployments, keep the default Hermes container user.
HERMES_UID=10000
HERMES_GID=10000

# Optional OpenAI-compatible Hermes API server.
# Keep it localhost-only unless a separate authenticated reverse proxy exists.
HXY_HERMES_API_SERVER_HOST=127.0.0.1
HXY_HERMES_API_SERVER_KEY=

# Feishu/Lark gateway settings.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ALLOWED_USERS=
FEISHU_ALLOW_BOTS=none
FEISHU_REQUIRE_MENTION=true
FEISHU_HOME_CHANNEL=
