HXY_DATABASE_URL="host=127.0.0.1 port=55433 dbname=hxy user=hxy_app password=change-me"
HXY_API_TOKEN=change-me
HXY_CORS_ORIGINS=http://127.0.0.1:8088,http://localhost:8088,http://127.0.0.1:18084,http://localhost:18084
HXY_MAX_UPLOAD_BYTES=10485760
HXY_MAX_MATERIAL_STORAGE_BYTES=1073741824
HXY_MIN_MATERIAL_FREE_BYTES=536870912

# Optional model router settings. Keep disabled until API auth and approved answer-card retrieval are stable.
HXY_MODEL_ROUTER_ENABLED=false
HXY_MODEL_CONFIG_PATH=/root/hxy/ops/env/hxy-model-router.toml
